# Opal web — devnet-only (copy to .env.local)
# cp .env.local.example .env.local

# Privy (public — safe in browser bundle)
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Solana devnet (same cluster when running `next dev` locally)
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
# WebSocket for Privy solana.rpcs (use provider's wss URL; do not guess from https)
NEXT_PUBLIC_SOLANA_RPC_WSS=wss://api.devnet.solana.com

# SERVER-ONLY — do not add until API routes exist
# PRIVY_APP_SECRET=
